        <!-- ======================================= -->
        <!-- POST /orders ROUTE LABEL (TOP)          -->
        <!-- ======================================= -->
        <mxCell id="post_label" value="" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#ED7100;strokeColor=none;opacity=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="490" width="960" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="post_text" value="&lt;font style='font-size:13px;'&gt;&lt;b style='color:#ED7100;'&gt;POST /orders&lt;/b&gt;&lt;span style='color:#6B7280;'&gt;  →  API Gateway routes to Lambda  →  Lambda calls put_item()  →  DynamoDB stores order  →  Returns 201 + order JSON&lt;/span&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="1035" y="493" width="930" height="44" as="geometry"/>
        </mxCell>

        <!-- ======================================= -->
        <!-- GET /orders ROUTE LABEL (BOTTOM)        -->
        <!-- ======================================= -->
        <mxCell id="get_label" value="" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#7AA116;strokeColor=none;opacity=12;" vertex="1" parent="1">
          <mxGeometry x="1020" y="750" width="960" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="get_text" value="&lt;font style='font-size:13px;'&gt;&lt;b style='color:#7AA116;'&gt;GET /orders&lt;/b&gt;&lt;span style='color:#6B7280;'&gt;  →  API Gateway routes to Lambda  →  Lambda calls scan()  →  DynamoDB returns all orders  →  Returns 200 + JSON array&lt;/span&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="1035" y="753" width="930" height="44" as="geometry"/>
        </mxCell>

        <!-- ======================================= -->
        <!-- CORS CALLOUT BOX                        -->
        <!-- ======================================= -->
        <mxCell id="cors_box" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFF3E2;strokeColor=#ED7100;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="870" width="500" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="cors_title" value="&lt;b style='font-size:14px;color:#ED7100;'&gt;⚡ CORS — The #1 Gotcha&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:12px;color:#46566B;'&gt;The page lives on S3 (&lt;code&gt;http://…s3-website…&lt;/code&gt;) and the API on&lt;br&gt;&lt;code&gt;https://…execute-api…&lt;/code&gt; — &lt;b&gt;different origins!&lt;/b&gt;&lt;br&gt;&lt;br&gt;The HTTP API has &lt;code&gt;cors_preflight&lt;/code&gt; enabled so the browser's&lt;br&gt;preflight OPTIONS request succeeds. curl/Postman skip CORS entirely.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="605" y="878" width="470" height="115" as="geometry"/>
        </mxCell>

        <!-- ======================================= -->
        <!-- CDK DEPLOYMENT BOX                      -->
        <!-- ======================================= -->
        <mxCell id="cdk_box" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#8C4FFF;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="870" width="500" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="cdk_title" value="&lt;b style='font-size:14px;color:#8C4FFF;'&gt;🚀 Deployed with AWS CDK&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:12px;color:#46566B;'&gt;One stack creates everything: DynamoDB table, Lambda function,&lt;br&gt;HTTP API with CORS, S3 bucket with public website config, and a&lt;br&gt;generated &lt;code&gt;config.js&lt;/code&gt; that wires the frontend to the API.&lt;br&gt;&lt;br&gt;&lt;code&gt;cdk deploy&lt;/code&gt; → outputs &lt;b&gt;SiteUrl&lt;/b&gt;, &lt;b&gt;ApiUrl&lt;/b&gt;, and &lt;b&gt;TableName&lt;/b&gt;&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1215" y="878" width="470" height="115" as="geometry"/>
        </mxCell>

        <!-- ======================================= -->
