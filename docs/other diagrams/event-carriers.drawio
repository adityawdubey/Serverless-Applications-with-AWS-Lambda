        <!-- Internal Steps -->
        <!-- Step style: rounded=12;fillColor=#FFFFFF;strokeColor=#F472B6;strokeWidth=1.5;shadow=1;shadowColor=#00000010;fontColor=#1F2937;fontSize=13;fontStyle=1; -->
        <mxCell id="step_receive" value="Receive" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F472B6;strokeWidth=1.5;shadow=1;shadowColor=#00000010;fontColor=#1F2937;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
