        </mxCell>
        <mxCell id="step_filter" value="Filter" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F472B6;strokeWidth=1.5;shadow=1;shadowColor=#00000010;fontColor=#1F2937;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="425" y="170" width="75" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="step_transform" value="Transform" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F472B6;strokeWidth=1.5;shadow=1;shadowColor=#00000010;fontColor=#1F2937;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="530" y="170" width="85" height="40" as="geometry"/>
        </mxCell>
