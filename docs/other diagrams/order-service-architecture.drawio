          <mxGeometry x="1800" y="870" width="430" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="demo_title" value="&lt;b style='font-size:14px;color:#1B7F47;'&gt;🎬 On-Stage Demo Script&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:12px;color:#46566B;'&gt;1. Place order in left panel (POST)&lt;br&gt;2. Refresh right panel — kitchen view (GET)&lt;br&gt;3. Order from DynamoDB appears instantly&lt;br&gt;4. Show DynamoDB console → real item in table&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1815" y="878" width="400" height="115" as="geometry"/>
