<mxfile host="draw.io" modified="2026-07-05" type="device">
  <diagram name="Event Carrier Internals" id="carrier_internals">
    <mxGraphModel dx="1200" dy="550" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Background -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="500" as="geometry"/>
        </mxCell>

        <!-- =======================
