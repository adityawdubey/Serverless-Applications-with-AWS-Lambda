        <mxCell id="e_r_d2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#F472B6;" edge="1" source="step_route" target="step_dispatch2" parent="1">
          <mxGeometry relative="1" as="geometry">
