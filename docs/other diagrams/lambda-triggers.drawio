<mxfile host="draw.io" modified="2026-07-04" type="device">
  <diagram name="Lambda Triggers" id="lambda-triggers">
    <mxGraphModel dx="1400" dy="1000" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- White Background -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry"/>
        </mxCell>

        <!-- ========== TITLE AREA ========== -->
        <mxCell id="subtitle" value="TRIGGERS" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontColor=#ED7100;fontStyle=1;spacing=2;letterSpacing=3;" vertex="1" parent="1">
          <mxGeometry x="60" y="25" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="title" value="&lt;font style='font-size:30px;color:#232F3E;'&gt;&lt;b&gt;What can wake a Lambda up?&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="52" width="700" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="intro_text" value="&lt;span style='font-size:13px;color:#6B7280;'&gt;Lambda functions are event-driven — they sleep until something triggers them. Here are the most common invocation sources in serverless architectures.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="900" height="35" as="geometry"/>
        </mxCell>

        <!-- Lambda Hero Icon (top right) -->
        <mxCell id="lambda_hero" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda" vertex="1" parent="1">
          <mxGeometry x="1065" y="35" width="78" height="78" as="geometry"/>
        </mxCell>

        <!-- ========== ROW 1 BACKGROUND BAND ========== -->
        <mxCell id="band1" value="" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="1120" height="130" as="geometry"/>
        </mxCell>

        <!-- ========== ROW 2 BACKGROUND BAND ========== -->
        <mxCell id="band2" value="" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="1120" height="130" as="geometry"/>
        </mxCell>

        <!-- ========== ROW 3 BACKGROUND BAND ========== -->
        <mxCell id="band3" value="" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="1120" height="130" as="geometry"/>
        </mxCell>

        <!-- ========== CARD 1: API Gateway ========== -->
        <mxCell id="card1" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8E8E8;strokeWidth=1;shadow=1;shadowColor=#00000015;" vertex="1" parent="1">
          <mxGeometry x="65" y="155" width="510" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="icon1" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway" vertex="1" parent="1">
          <mxGeometry x="90" y="166" width="68" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="text1" value="&lt;b style='font-size:17px;color:#232F3E;'&gt;API Gateway&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:13px;color:#6B7280;'&gt;An HTTP request hits your endpoint. Build REST or&lt;br&gt;WebSocket APIs that invoke Lambda on every call.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="175" y="165" width="385" height="70" as="geometry"/>
        </mxCell>

        <!-- ========== CARD 2: S3 ========== -->
        <mxCell id="card2" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8E8E8;strokeWidth=1;shadow=1;shadowColor=#00000015;" vertex="1" parent="1">
          <mxGeometry x="625" y="155" width="510" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="icon2" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3" vertex="1" parent="1">
          <mxGeometry x="650" y="166" width="68" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="text2" value="&lt;b style='font-size:17px;color:#232F3E;'&gt;S3&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:13px;color:#6B7280;'&gt;A file is uploaded to a bucket. React to object&lt;br&gt;creates, deletes, or modifications in real time.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="735" y="165" width="385" height="70" as="geometry"/>
        </mxCell>

        <!-- ========== CARD 3: DynamoDB Streams ========== -->
        <mxCell id="card3" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8E8E8;strokeWidth=1;shadow=1;shadowColor=#00000015;" vertex="1" parent="1">
          <mxGeometry x="65" y="305" width="510" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="icon3" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb" vertex="1" parent="1">
          <mxGeometry x="90" y="316" width="68" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="text3" value="&lt;b style='font-size:17px;color:#232F3E;'&gt;DynamoDB Streams&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:13px;color:#6B7280;'&gt;A row changes in your table. Capture inserts, updates,&lt;br&gt;and deletes to trigger downstream processing.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="175" y="315" width="385" height="70" as="geometry"/>
        </mxCell>

        <!-- ========== CARD 4: EventBridge / cron ========== -->
        <mxCell id="card4" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8E8E8;strokeWidth=1;shadow=1;shadowColor=#00000015;" vertex="1" parent="1">
          <mxGeometry x="625" y="305" width="510" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="icon4" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eventbridge" vertex="1" parent="1">
          <mxGeometry x="650" y="316" width="68" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="text4" value="&lt;b style='font-size:17px;color:#232F3E;'&gt;EventBridge / cron&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:13px;color:#6B7280;'&gt;A schedule fires, or an event is published. Run cron&lt;br&gt;jobs or react to events across AWS services &amp;amp; SaaS.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="735" y="315" width="385" height="70" as="geometry"/>
        </mxCell>

        <!-- ========== CARD 5: SQS / SNS ========== -->
        <mxCell id="card5" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8E8E8;strokeWidth=1;shadow=1;shadowColor=#00000015;" vertex="1" parent="1">
          <mxGeometry x="65" y="455" width="510" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="icon5" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sqs" vertex="1" parent="1">
          <mxGeometry x="90" y="466" width="68" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="text5" value="&lt;b style='font-size:17px;color:#232F3E;'&gt;SQS / SNS&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:13px;color:#6B7280;'&gt;A message lands on a queue or topic. Decouple&lt;br&gt;microservices with async, fan-out, or batch processing.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="175" y="465" width="385" height="70" as="geometry"/>
        </mxCell>

        <!-- ========== CARD 6: ...and many more ========== -->
        <mxCell id="card6" value="" style="rounded=14;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E8E8E8;strokeWidth=1;shadow=1;shadowColor=#00000015;" vertex="1" parent="1">
          <mxGeometry x="625" y="455" width="510" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="icon6" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda" vertex="1" parent="1">
