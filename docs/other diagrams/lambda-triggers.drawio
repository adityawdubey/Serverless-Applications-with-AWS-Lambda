        </mxCell>
        <mxCell id="text6" value="&lt;b style='font-size:17px;color:#232F3E;'&gt;...and many more&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:13px;color:#6B7280;'&gt;Direct SDK / CLI invoke, IoT Rules, Kinesis Data&lt;br&gt;Streams, Cognito triggers, CloudWatch Logs &amp;amp; Alarms.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="735" y="465" width="385" height="70" as="geometry"/>
