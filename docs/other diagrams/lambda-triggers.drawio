        <mxCell id="footer_text" value="&lt;span style='color:#6B7280;font-size:12px;'&gt;💡 Lambda supports 200+ event source integrations — these are just the most common ones.&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
